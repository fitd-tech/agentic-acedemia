{
  "model": "claude-sonnet-4-6",
  "enabledMcpjsonServers": ["filesystem"],
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash experiments/hooks/secret-scanner.sh"
          },
          {
            "type": "command",
            "command": "bash experiments/hooks/commit-normalizer.sh"
          },
          {
            "type": "command",
            "command": "bash experiments/hooks/dry-run-injector.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash experiments/hooks/edit-logger.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash experiments/context-management/pre-compact.sh"
          }
        ]
      }
    ]
  }
}
